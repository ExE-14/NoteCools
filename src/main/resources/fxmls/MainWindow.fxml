<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="860.0" styleClass="root-pane" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.work_edition.controllers.MainWindowController">

    <!-- Главный заголовок -->
    <Label fx:id="mainTitleLabel" alignment="CENTER" layoutX="60.0" layoutY="80.0" prefHeight="46.0" prefWidth="740.0" styleClass="main-title" text="Добро пожаловать в приложение заметок с приоритетом!" />

    <!-- Подзаголовок -->
    <Label fx:id="subtitleLabel" alignment="CENTER" layoutX="199.0" layoutY="135.0" prefHeight="25.0" prefWidth="462.0" styleClass="subtitle" text="Заметки везде, где не пожелаешь!" />

    <!-- Панель с тремя кнопками -->
    <Pane layoutX="130.0" layoutY="277.0" prefHeight="64.0" prefWidth="600.0">
        <Button fx:id="settingsButton" layoutX="14.0" layoutY="20.0" onAction="#handleSettings" prefHeight="25.0" prefWidth="130.0" styleClass="nav-button" text="Настройки" />
        <Button fx:id="notesButton" layoutX="235.0" layoutY="20.0" onAction="#handleNotes" prefHeight="25.0" prefWidth="130.0" styleClass="nav-button" text="Заметки" />
        <Button fx:id="helpButton" layoutX="456.0" layoutY="20.0" onAction="#handleHelp" prefHeight="25.0" prefWidth="130.0" styleClass="nav-button" text="Help" />
    </Pane>

    <!-- Разделитель -->
    <Separator layoutX="130.0" layoutY="383.0" prefWidth="600.0" styleClass="separator" />

    <!-- Контакты -->
    <Button fx:id="contactsButton" layoutX="315.0" layoutY="420.0" onAction="#handleContacts" prefHeight="25.0" prefWidth="230.0" styleClass="contacts-button" text="Контакты" />

</AnchorPane>
