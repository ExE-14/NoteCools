<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="860.0" styleClass="root-pane" stylesheets="/styles/SettingsWindowStyle.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.work_edition.controllers.SettingsWindowController">

    <VBox alignment="BOTTOM_RIGHT" layoutX="14.0" layoutY="480.0" prefHeight="56.0" prefWidth="200.0">
        <Button fx:id="saveButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="28.0" prefWidth="200.0" text="Сохранить" />
        <Separator prefHeight="24.0" prefWidth="200.0" />
        <Button fx:id="cancelButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="25.0" prefWidth="202.0" text="Отмена" />
    </VBox>

    <!-- Панель с изображением и надписью "Settings" МНЕ БЫЛО ЛЕНЬ ДЕЛАТЬ ПОСЛЕДОВАТЕЛЬНУЮ АНИМАЦИЮ, И Я ПРОСТО СДЕЛАЛ ПАНЕЛЬ И НА НЕЕ АНИМУ КИНУЛ -->
    <Pane fx:id="pane" layoutX="14.0" layoutY="14.0" prefHeight="208.0" prefWidth="200.0">
        <ImageView fx:id="imageView" fitHeight="150.0" fitWidth="184.0" layoutX="22.0" layoutY="7.0" nodeOrientation="INHERIT" pickOnBounds="true" preserveRatio="true">
        </ImageView>
        <Label alignment="CENTER" contentDisplay="CENTER" layoutX="60.0" layoutY="174.0" prefHeight="17.0" prefWidth="80.0" text="Settings">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>
    </Pane>
    <Separator layoutX="224.0" layoutY="190.0" orientation="VERTICAL" prefHeight="221.0" prefWidth="6.0" />
    <Separator layoutX="224.0" layoutY="14.0" orientation="VERTICAL" prefHeight="142.0" prefWidth="0.0" />
   <Separator layoutX="224.0" layoutY="446.0" orientation="VERTICAL" prefHeight="142.0" prefWidth="0.0" />
</AnchorPane>
